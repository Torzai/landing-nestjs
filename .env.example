MONGODB_URI=mongodb://localhost:27017/mentoria
GMAIL_USER=tu-email@gmail.com
GMAIL_PASSWORD=tu-app-password

# Origen permitido para CORS (URL del frontend)
CORS_ORIGIN=http://localhost:4200

# JWT - genera un secreto largo y aleatorio, p.ej: openssl rand -hex 32
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
# Duración del token en segundos (28800 = 8h)
JWT_EXPIRES_IN=28800

# Credenciales del panel admin
# Genera el hash con: npm run hash-password -- "tu-password"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
